# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_FORM_ENDPOINT=/api/contact

# Form Service (choose one)
# Option 1: Formspree.io
VITE_FORMSPREE_ID=your_formspree_id
# OR
# Option 2: Netlify Forms (leave as is for netlify forms)
# OR
# Option 3: Custom API endpoint
VITE_CONTACT_API=https://your-api-endpoint.com/api/contact

# Monitoring & Analytics
VITE_SENTRY_DSN=
VITE_GA_ID=

# Cloud Storage (for image optimization)
VITE_CLOUDINARY_NAME=
VITE_CLOUDINARY_PRESET=

# Security
VITE_CSRF_TOKEN_ENDPOINT=/api/csrf-token
VITE_RATE_LIMIT_PER_MINUTE=5

# Navigation
VITE_SITE_URL=https://phalendrone-works.com
VITE_CONTACT_EMAIL=info@phalendrone.com
VITE_CONTACT_PHONE=+27123456789
